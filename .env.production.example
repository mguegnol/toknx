# Public domains
TOKNX_API_DOMAIN=api.example.com
TOKNX_DASHBOARD_DOMAIN=toknx.example.com
TOKNX_ACME_EMAIL=admin@example.com
TOKNX_TRAEFIK_NETWORK=shared-proxy
TOKNX_POSTGRES_DB=toknx
TOKNX_POSTGRES_USER=toknx
TOKNX_POSTGRES_PASSWORD=change-me

# Coordinator runtime
TOKNX_PUBLIC_BASE_URL=https://api.example.com
TOKNX_NODE_TUNNEL_PUBLIC_BASE_URL=wss://api.example.com
TOKNX_DATABASE_URL=postgresql+asyncpg://toknx:change-me@postgres:5432/toknx
TOKNX_REDIS_URL=redis://redis:6379/0
TOKNX_GITHUB_CLIENT_ID=
TOKNX_GITHUB_CLIENT_SECRET=
TOKNX_GITHUB_REDIRECT_URL=https://api.example.com/auth/github/callback
TOKNX_JWT_SECRET=change-me
TOKNX_AUTH_DEV_BYPASS=false
TOKNX_COORDINATOR_SIGNUP_BONUS=20000
TOKNX_NODE_STAKE_CREDITS=500
TOKNX_QUEUE_TIMEOUT_SECONDS=30
TOKNX_MODEL_QUEUE_CAP=100
TOKNX_ACCOUNT_INFLIGHT_LIMIT=5
TOKNX_NODE_KEEPALIVE_SECONDS=30
TOKNX_NODE_OFFLINE_AFTER_SECONDS=90
TOKNX_FEE_PERCENT=10
TOKNX_DASHBOARD_ORIGIN=https://toknx.example.com

# Dashboard runtime
TOKNX_PUBLIC_API_BASE=http://coordinator:8000
VITE_TOKNX_API_BASE=https://api.example.com
